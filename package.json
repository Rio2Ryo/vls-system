{
  "name": "vls-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "face:min": "python3 scripts/generate-synthetic-dataset.py --out data/test/face-search-min && python3 scripts/check-face-test-data.py --root data/test/face-search-min --min-model 3 --min-match 6 --min-non-match 12 --min-race-scene 4 --expect-min-gallery 20 --expect-max-gallery 30 && python3 scripts/smoke-test-face-search.py --root data/test/face-search-min",
    "face:check": "python3 scripts/check-face-test-data.py --root data/test/face-search-min --min-model 3 --min-match 6 --min-non-match 12 --min-race-scene 4 --expect-min-gallery 20 --expect-max-gallery 30",
    "face:smoke": "python3 scripts/smoke-test-face-search.py --root data/test/face-search-min",
    "face:bundle": "bash scripts/package-face-test-data.sh data/test/face-search-min data/test/face-search-min-bundle.zip",
    "face:report": "python3 scripts/face-min-report.py --root data/test/face-search-min --out data/test/face-search-min/report.json"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@sentry/nextjs": "^10.40.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "chart.js": "^4.5.1",
    "encoding": "^0.1.13",
    "framer-motion": "^12.34.3",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.3",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18",
    "react-grid-layout": "^2.2.2",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "stripe": "^20.4.0",
    "swr": "^2.4.1",
    "web-push": "^3.6.7",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-grid-layout": "^1.3.6",
    "@types/web-push": "^3.6.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
